# .env.prod.template — copy to /opt/nitrag/.env on mlcpu and fill in secrets
# This file is checked into git; the real .env is NOT.

# ── OpenAI (for openai_cloud preset) ─────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── 6kpro vLLM (for qwen_6kpro preset) ───────────────────────────────────────
VLLM_BASE_URL=http://172.16.5.100:8000/v1
VLLM_API_KEY=dummy

# ── Default preset used when no preset is specified in API requests ───────────
# Options: openai_cloud | qwen_6kpro | medical_precise | local_ollama | fast_local
NITRAG_DEFAULT_PRESET=qwen_6kpro

# ── Embeddings (fastembed runs locally on the server, no remote needed) ───────
NITRAG_EMBED_PROVIDER=fastembed
NITRAG_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5

# ── NSQ (mlcpu is the NSQ host, consumers are on the same machine) ────────────
NSQ_NSQD_TCP=127.0.0.1:4150
NSQ_LOOKUPD_HTTP=http://127.0.0.1:4161
