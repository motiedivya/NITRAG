{
  "embedding": {
    "provider": "fastembed",
    "model_name": "nomic-ai/nomic-embed-text-v1.5",
    "base_url": null,
    "api_key": null,
    "dimensions": 768,
    "batch_size": 64,
    "normalize": true,
    "device": "cpu",
    "max_length": null
  },
  "llm": {
    "provider": "openai_compatible",
    "model_name": "llama3.1:8b",
    "base_url": "http://localhost:11434/v1",
    "api_key": "ollama",
    "temperature": 0.1,
    "max_tokens": 2048,
    "timeout_seconds": 120,
    "system_prompt": null
  },
  "vector_index": {
    "backend": "faiss",
    "index_type": "flat",
    "metric": "cosine",
    "hnsw_ef_construction": 200,
    "hnsw_m": 16,
    "hnsw_ef_search": 100,
    "qdrant_url": "http://localhost:6333",
    "qdrant_api_key": null,
    "qdrant_collection_prefix": "nitrag"
  },
  "retrieval": {
    "retriever_names": ["bm25", "dense", "hybrid"],
    "chunk_strategy_name": "block_group_800_overlap_1",
    "reranker_name": "hybrid_weighted",
    "top_k_retrieve": 20,
    "top_k_rerank": 5,
    "hybrid_alpha": 0.5,
    "use_hyde": false,
    "query_expansion": true
  },
  "generation": {
    "max_context_tokens": 3500,
    "context_ordering": "score",
    "include_metadata_in_context": true,
    "min_citation_confidence": 0.25,
    "hallucination_check": true,
    "structured_output": true
  }
}
